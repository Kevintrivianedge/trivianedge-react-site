/* Redirect Rules for Cloudflare Workers */

// Simple Redirect Example:
// Redirect /old-url to /new-url
redirect("/old-url", "/new-url");

// Permanent Redirect (301)
// Redirect /temp to /new-temporary
redirect("/temp", "/new-temporary", 301);

// Redirect with status code
// Redirect /another-old-url to /another-new-url with a 302 status
redirect("/another-old-url", "/another-new-url", 302);

// You can also add conditions to redirects:
// Redirect /conditional-url based on some condition
if (testCondition()) {
    redirect("/conditional-url", "/conditional-new-url");
}