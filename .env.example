# ─────────────────────────────────────────────────────────────
# TrivianEdge — required secrets & environment variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Cloudflare Workers (required for deployment) ─────────────

# Your Cloudflare API token. Used by wrangler to authenticate deployments.
# Generate at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Your Cloudflare account ID (found in the Cloudflare dashboard sidebar).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ── Worker secrets (set via wrangler, not .env) ───────────────
# These are NOT read from .env files in production. Set them with:
#   wrangler secret put GEMINI_API_KEY
#   wrangler secret put RESEND_API_KEY
#
# For local wrangler dev, create a .dev.vars file (already gitignored) with:
#
#   GEMINI_API_KEY=your_google_gemini_api_key
#   RESEND_API_KEY=your_resend_api_key

# ── Google Gemini (required for AI features) ──────────────────
# Obtain at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Resend (optional — enables early-access email notifications) ─
# Obtain at: https://resend.com/api-keys
# If unset, early-access form submissions are accepted silently.
RESEND_API_KEY=your_resend_api_key_here
